# Copy this file to .env and fill in real values. Never commit .env.

# Signing key for JWT access/refresh tokens. Required in production.
# Generate one with: openssl rand -hex 32
SECRET_KEY=

# Origin the browser app is served from. The backend only accepts
# cross-origin requests (and cookies) from this exact origin.
FRONTEND_ORIGIN=http://localhost:5173

# Turso (hosted libSQL) connection. Leave both blank to fall back to a local
# file database (file:local.db) for offline development.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional overrides
# PORT=3001
# NODE_ENV=development
